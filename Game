            const rng = Math.random();
            let sum = 0;
            let selected = SPIRIT_ROOT_POOL[2]; 

            for (let root of SPIRIT_ROOT_POOL) {
                sum += root.rate;
                if (rng <= sum) {
                    selected = root;
                    break;
                }
            }

            state.spiritRoot = selected.name;
            state.spiritRootBuff = selected.buff;
            state.element = ELEMENTS[Math.floor(Math.random() * ELEMENTS.length)];

            if (showToast) {
                sendSystemNotification(`Đạo cốt tẩy tủy! Ngộ đắc [${state.spiritRoot}] (${state.spiritRootBuff >= 0 ? '+' : ''}${state.spiritRootBuff * 100}% Linh Khí) - Ngũ hành: [${state.element}]`, "success");
            }
        }

