        /* --- LÔI KIẾP PHI THĂNG SIÊU KHÓ --- */
        function initiateTribulationFlow() {
            const realms = getCurrentRealmsDatabase();
            const currRealm = realms[state.realmIndex];

            state.hp = state.maxHp;

            const tribulationElement = ELEMENTS[Math.floor(Math.random() * ELEMENTS.length)];

            activeTribulation = {
                currentStrike: 0,
                maxStrikes: 9,
                nextStrikeTimer: 15,
                activeLightning: [],
                element: tribulationElement,
                title: `${currRealm.name} Đỉnh Phong Phi Thăng!`
            };

            document.getElementById('trib-title-details').innerText = activeTribulation.title;
            document.getElementById('trib-strike-text').innerText = "Vũ trụ lôi vân đang kéo tới...";
            
            const relation = ELEMENT_RELATIONS[state.element];
            const noticeEl = document.getElementById('tribulation-element-notice');
            if (activeTribulation.element === relation.beatenBy) {
                noticeEl.className = "mt-2 flex justify-center text-[10px] text-red-500 font-bold animate-pulse";
                noticeEl.innerText = `⚠️ Cảnh Báo: Thiên Kiếp [Hệ ${activeTribulation.element}] KHẮC Chân Thân [Hệ ${state.element}] (Sát thương +60%!)`;
            } else if (activeTribulation.element === relation.beats) {
                noticeEl.className = "mt-2 flex justify-center text-[10px] text-emerald-400 font-bold";
                noticeEl.innerText = `✨ Thiên Cơ: Chân Thân [Hệ ${state.element}] KHẮC Chế Thiên Kiếp [Hệ ${activeTribulation.element}] (Sát thương -20%!)`;
            } else {
                noticeEl.className = "mt-2 flex justify-center text-[10px] text-slate-400 font-semibold";
                noticeEl.innerText = `☯️ Thiên lôi thuộc tính: [Hệ ${activeTribulation.element}] | Chân Thân thuộc tính: [Hệ ${state.element}]`;
            }

            updateTribulationPotionCount();
            document.getElementById('overlay-tribulation').classList.remove('hidden');
            updateTribulationUI();
            sendSystemNotification("Khởi động lôi kiếp sấm giật!", "warning");
        }

        function updateTribulationUI() {
            if (!activeTribulation) return;
            document.getElementById('trib-hp-display').innerText = `${Math.floor(state.hp)}/${state.maxHp}`;
            const pct = Math.max(0, (state.hp / state.maxHp) * 100);
            document.getElementById('trib-hp-fill').style.width = `${pct}%`;
            document.getElementById('trib-qi-display').innerText = formatNumber(state.qi);
        }

        function updateTribulationPotionCount() {
            const count = state.inventory.filter(i => i.type === 'hp_pill').length;
            document.getElementById('trib-potion-count').innerText = `${count} Đan Dược`;
        }

        function invocateShieldBarrier() {
            if (!activeTribulation) return;
            const cost = 500;
            if (state.qi >= cost) {
                state.qi -= cost;
                activeTribulation.barrierActive = true;
                playSoundMeditation();
                updateTribulationUI();
                updateAllUI();
                sendSystemNotification("Gia trì hộ thể chân khí!", "success");
            } else {
                sendSystemNotification("Thiếu linh khí gánh chịu lôi môn!", "error");
            }
        }

        function consumePillDuringTribulation() {
            if (!activeTribulation) return;
            const idx = state.inventory.findIndex(i => i.type === 'hp_pill');
            if (idx !== -1) {
                const pill = state.inventory[idx];
                state.hp = Math.min(state.maxHp, state.hp + pill.healHp);
                state.inventory.splice(idx, 1);
                
                playSoundAscend();
                updateTribulationUI();
                updateTribulationPotionCount();
                updateAllUI();
                sendSystemNotification(`Uống Hồi Xuân Đan, khôi phục +${pill.healHp} HP!`, "success");
            } else {
                sendSystemNotification("Đã cạn sạch đan dược phòng thân!", "error");
            }
        }

        function runTribulationTick() {
            if (!activeTribulation) return;
            activeTribulation.nextStrikeTimer--;

            if (activeTribulation.nextStrikeTimer <= 0) {
                activeTribulation.currentStrike++;
                strikeThunderbolt(activeTribulation.currentStrike);

                if (activeTribulation.currentStrike < activeTribulation.maxStrikes) {
                    activeTribulation.nextStrikeTimer = 22; 
                } else {
                    activeTribulation.nextStrikeTimer = 999999;
                    setTimeout(completeBreakthroughSuccess, 1200);
                }
            }
        }

        function strikeThunderbolt(strikeIndex) {
            const app = document.getElementById('game-app');
            app.classList.add('shake');
            setTimeout(() => { app.classList.remove('shake'); }, 300);

            playSoundLôiKiếp();

            // SÁT THƯƠNG THIÊN LÔI GẤP 3 LẦN TRƯỚC (SIÊU KHÓ)
            const baseDmg = ((state.worldIndex * 120) + (state.realmIndex * 60) + (strikeIndex * 20) + 40);
            let finalDmg = Math.floor(baseDmg);

            // Giảm sát thương nếu mang Linh Thú (Sẻ chia một phần gánh nặng kiếp phạt)
            let totalHpShare = 0;
            state.pets.forEach(pet => {
                totalHpShare += pet.hpShare;
            });
            totalHpShare = Math.min(0.40, totalHpShare); // San sẻ tối đa 40%

            if (totalHpShare > 0) {
                const sharedDmg = Math.floor(finalDmg * totalHpShare);
                finalDmg -= sharedDmg;
                sendSystemNotification(`Linh Thú hộ tống san sẻ -${sharedDmg} sát thương Lôi Kiếp!`, "info");
            }

            const relation = ELEMENT_RELATIONS[state.element];
            if (activeTribulation.element === relation.beatenBy) {
                finalDmg = Math.floor(finalDmg * 1.60); // Đột biến sát thương khi bị khắc
            } else if (activeTribulation.element === relation.beats) {
                finalDmg = Math.floor(finalDmg * 0.80); 
            }

            if (activeTribulation.barrierActive) {
                finalDmg = Math.floor(finalDmg * 0.45);
                activeTribulation.barrierActive = false;
                sendSystemNotification("Chân lực bảo hộ giảm 55% sát thương!", "info");
            }

            state.hp = Math.max(0, state.hp - finalDmg);
            updateTribulationUI();

            const slots = ['armor', 'artifact'];
            slots.forEach(slot => {
                const item = state.equipment[slot];
                if (item) item.durability = Math.max(0, (item.durability || 100) - 5); // Tăng mài mòn trang bị
            });
            recalculateStats();

            document.getElementById('trib-strike-text').innerText = `⚡ Đệ ${strikeIndex} Trọng Thiên Lôi (${activeTribulation.element}) tàn phá -${finalDmg} HP!`;
            createLightningPath(strikeIndex);

            if (state.hp <= 0) {
                activeTribulation.nextStrikeTimer = 999999;
                setTimeout(handleBreakthroughFailure, 800);
            }
        }

        function createLightningPath(strikeIndex) {
            if (!activeTribulation) return;
            const canvas = document.getElementById('lightning-canvas');
            const lines = [];
            const segments = 12;
            const startX = canvas.width / 2 + (Math.random() * 80 - 40);
            const startY = 0;
            const endX = canvas.width / 2;
            const endY = canvas.height * 0.45;

            let currX = startX;
            let currY = startY;

            for (let i = 0; i < segments; i++) {
                const nextY = (canvas.height * 0.45 / segments) * (i + 1);
                const nextX = currX + (Math.random() * 30 - 15);
                lines.push({ x1: currX, y1: currY, x2: nextX, y2: nextY });
                currX = nextX;
                currY = nextY;
            }

            let boltColor = '#06b6d4';
            if (activeTribulation.element === 'Hỏa') boltColor = '#ef4444';
            else if (activeTribulation.element === 'Kim') boltColor = '#eab308';
            else if (activeTribulation.element === 'Mộc') boltColor = '#10b981';
            else if (activeTribulation.element === 'Thổ') boltColor = '#b45309';

            activeTribulation.activeLightning.push({
                lines: lines,
                life: 12,
                thickness: 2.0 + strikeIndex * 0.7, // Làm lôi điện to và hung dữ hơn
                color: strikeIndex === 9 ? '#ef4444' : boltColor
            });
        }

        function drawLightningFrames() {
            if (!activeTribulation || activeTribulation.activeLightning.length === 0) return;
            const canvas = document.getElementById('lightning-canvas');
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            activeTribulation.activeLightning.forEach((bolt, idx) => {
                ctx.beginPath();
                ctx.strokeStyle = bolt.color;
                ctx.lineWidth = bolt.thickness;
                ctx.shadowColor = bolt.color;
                ctx.shadowBlur = 15;

                bolt.lines.forEach(l => {
                    ctx.moveTo(l.x1, l.y1);
                    ctx.lineTo(l.x2, l.y2);
                });

                ctx.stroke();
                bolt.life--;

                if (bolt.life <= 0) {
                    activeTribulation.activeLightning.splice(idx, 1);
                }
            });
        }

