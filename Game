<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Thiên Đạo Vô Hạn V8 - Vạn Thế Gia Tộc</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800;900&family=Quicksand:wght@400;600;700&display=swap');

        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #020617;
            color: #f3f4f6;
            overflow: hidden;
            touch-action: manipulation;
        }

        .font-immortal {
            font-family: 'Cinzel', serif;
        }

        /* Chất lượng trang bị màu sắc */
        .rarity-0 { color: #94a3b8; border-color: #475569; text-shadow: 0 0 5px rgba(148,163,184,0.3); } 
        .rarity-1 { color: #3b82f6; border-color: #1d4ed8; text-shadow: 0 0 5px rgba(59,130,246,0.3); } 
        .rarity-2 { color: #a855f7; border-color: #7e22ce; text-shadow: 0 0 8px rgba(168,85,247,0.4); } 
        .rarity-3 { color: #f97316; border-color: #c2410c; text-shadow: 0 0 10px rgba(249,115,22,0.5); } 
        .rarity-4 { color: #ef4444; border-color: #b91c1c; text-shadow: 0 0 15px rgba(239,68,68,0.6); } 

        .bg-rarity-0 { background-color: rgba(71, 85, 105, 0.15); }
        .bg-rarity-1 { background-color: rgba(29, 78, 216, 0.15); }
        .bg-rarity-2 { background-color: rgba(126, 34, 206, 0.15); }
        .bg-rarity-3 { background-color: rgba(194, 65, 12, 0.15); }
        .bg-rarity-4 { background-color: rgba(185, 28, 28, 0.15); }

        .bg-mystic {
            background: radial-gradient(circle at center, #011d24 0%, #030712 85%, #000000 100%);
        }

        .shake {
            animation: shakeScreen 0.25s ease-in-out;
        }

        @keyframes shakeScreen {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            15% { transform: translate(-6px, 6px) rotate(-1.5deg); }
            30% { transform: translate(6px, -6px) rotate(1.5deg); }
            45% { transform: translate(-6px, -3px) rotate(-0.8deg); }
            60% { transform: translate(6px, 6px) rotate(1.5deg); }
            75% { transform: translate(-3px, 3px) rotate(-0.5deg); }
            90% { transform: translate(3px, -3px) rotate(0.3deg); }
        }

        .breath-aura {
            animation: breath 5s ease-in-out infinite;
        }

        @keyframes breath {
            0%, 100% { transform: scale(1); opacity: 0.15; filter: blur(12px); }
            50% { transform: scale(1.15); opacity: 0.35; filter: blur(18px); }
        }

        .pulse-glow {
            animation: pulseGlow 2.5s infinite alternate;
        }

        @keyframes pulseGlow {
            0% { box-shadow: 0 0 5px rgba(6, 182, 212, 0.15); }
            100% { box-shadow: 0 0 18px rgba(6, 182, 212, 0.4); }
        }

        .glass-tab {
            background: rgba(8, 12, 24, 0.95);
            backdrop-filter: blur(16px);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Hạt thăng thiên hiệu ứng */
        .ascend-particle {
            position: absolute;
            pointer-events: none;
            border-radius: 50%;
            animation: floatUp 2.2s ease-out forwards;
        }

        @keyframes floatUp {
            0% { transform: translateY(100px) scale(0.4); opacity: 1; }
            100% { transform: translateY(-500px) scale(2.2); opacity: 0; }
        }
    </style>
</head>
<body class="h-screen w-screen flex justify-center items-center bg-black select-none">

    <div id="game-app" class="w-full h-full max-w-md bg-mystic relative flex flex-col shadow-2xl overflow-hidden border border-gray-950">
        
        <!-- Ambient Particles Layer -->
        <div id="ambient-layer" class="absolute inset-0 pointer-events-none z-0 overflow-hidden"></div>
        <div id="toast-layer" class="absolute top-16 left-1/2 -translate-x-1/2 w-11/12 z-50 flex flex-col gap-1.5 pointer-events-none"></div>

        <!-- TOP BAR -->
        <div class="w-full p-3 flex justify-between items-start z-10 bg-gradient-to-b from-black via-black/70 to-transparent">
            <div>
                <div class="flex items-center space-x-1">
                    <span id="world-badge" class="px-2 py-0.5 rounded text-[9px] font-bold tracking-wider bg-slate-800 text-slate-300">PHÀM GIỚI</span>
                    <span id="faction-badge" class="px-2 py-0.5 rounded text-[9px] font-bold bg-zinc-800 text-zinc-400 hidden">VÔ PHÁI</span>
                </div>
                <div class="flex items-center space-x-1 mt-1.5">
                    <span class="text-amber-400 text-xs">💎</span>
                    <span id="currency-gems" class="text-amber-400 font-mono text-xs font-bold">0</span>
                    <span class="text-[8.5px] text-gray-400 ml-1.5">Uy danh: <span id="clan-fame" class="text-indigo-400 font-bold">0</span></span>
                </div>
            </div>
            
            <div class="flex flex-col items-end">
                <div class="flex items-center space-x-1.5 bg-slate-900/90 border border-cyan-500/20 px-2.5 py-0.5 rounded-full pulse-glow">
                    <span class="text-[9px] text-cyan-400 font-bold tracking-wider">⚔ LỰC CHIẾN:</span>
                    <span id="power-display" class="text-xs text-white font-mono font-bold">10</span>
                </div>
                <div class="flex items-center space-x-1.5 mt-1 text-[9px]">
                    <span class="text-emerald-400 font-bold">📅 Năm <span id="game-year">1</span> - <span id="game-month">1</span> Nguyệt</span>
                    <button onclick="toggleAudioMute()" class="text-slate-500 hover:text-slate-300">🔊</button>
                </div>
            </div>
        </div>

        <!-- MAIN VIEWS -->
        <div class="flex-1 flex flex-col relative overflow-hidden z-10 px-4">
            
            <!-- TAB 1: TU LUYỆN -->
            <div id="view-cultivate" class="flex-1 flex flex-col justify-between py-4 space-y-4">
                
                <!-- Matrix Grid -->
                <div class="flex items-center justify-between space-x-4 bg-slate-950/50 p-3 rounded-xl border border-slate-900">
                    <!-- Left EQ -->
                    <div class="flex flex-col space-y-3">
                        <div id="eq-weapon" onclick="unequipItem('weapon')" class="w-11 h-11 rounded-lg border border-dashed border-slate-800 flex flex-col items-center justify-center cursor-pointer hover:border-slate-400 bg-black/40">
                            <span class="text-[8px] text-gray-500">Vũ Khí</span>
                        </div>
                        <div id="eq-armor" onclick="unequipItem('armor')" class="w-11 h-11 rounded-lg border border-dashed border-slate-800 flex flex-col items-center justify-center cursor-pointer hover:border-slate-400 bg-black/40">
                            <span class="text-[8px] text-gray-500">Pháp Y</span>
                        </div>
                    </div>

                    <!-- Character Aura -->
                    <div class="relative flex-1 flex flex-col items-center justify-center py-2">
                        <div id="aura-circle" class="breath-aura absolute w-32 h-32 rounded-full bg-cyan-500/15 z-0"></div>
                        <div class="relative w-24 h-24 rounded-full border border-cyan-500/20 bg-slate-900/80 flex items-center justify-center z-10">
                            <span id="char-avatar" class="text-5xl filter drop-shadow-[0_0_15px_rgba(6,182,212,0.5)]">🧘‍♂️</span>
                        </div>

                        <!-- HP display -->
                        <div class="w-full max-w-[120px] bg-slate-950 rounded-full border border-red-950 p-[1px] mt-2 z-10">
                            <div id="char-hp-fill" class="h-1.5 bg-gradient-to-r from-red-600 to-rose-500 rounded-full" style="width: 100%"></div>
                            <div class="text-[7.5px] text-center font-bold text-red-300 mt-0.5">HP: <span id="char-hp-text">100/100</span></div>
                        </div>

                        <!-- Linh Căn & Ngũ Hành Badge -->
                        <div class="mt-2 z-10 flex flex-col items-center space-y-1">
                            <span id="spirit-root-display" class="px-2 py-0.5 rounded text-[8px] font-bold text-yellow-300 bg-amber-950/40 border border-yellow-500/20 shadow-sm">Khởi Tạo Linh Căn...</span>
                            <div class="flex space-x-1">
                                <span id="element-display" class="text-[8px] font-bold text-cyan-400 px-1 bg-cyan-950/50 rounded border border-cyan-500/20">Hệ: Thủy</span>
                                <button onclick="reRollSpiritRoot()" class="text-[7.5px] font-bold text-amber-400 hover:text-amber-300 underline bg-black/40 px-1 rounded border border-amber-900/30">Tẩy Tủy (100💎)</button>
                            </div>
                        </div>
                    </div>

                    <!-- Right EQ -->
                    <div class="flex flex-col space-y-3">
                        <div id="eq-accessory" onclick="unequipItem('accessory')" class="w-11 h-11 rounded-lg border border-dashed border-slate-800 flex flex-col items-center justify-center cursor-pointer hover:border-slate-400 bg-black/40">
                            <span class="text-[8px] text-gray-500">Trang Sức</span>
                        </div>
                        <div id="eq-artifact" onclick="unequipItem('artifact')" class="w-11 h-11 rounded-lg border border-dashed border-slate-800 flex flex-col items-center justify-center cursor-pointer hover:border-slate-400 bg-black/40">
                            <span class="text-[8px] text-gray-500">Pháp Bảo</span>
                        </div>
                    </div>
                </div>

                <!-- Progress Details -->
                <div class="w-full text-center">
                    <h2 id="realm-title" class="font-immortal text-xl font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-cyan-200 via-white to-cyan-200">
                        Luyện Khí Tầng 1
                    </h2>
                    
                    <!-- Auto breakthrough selector and stats -->
                    <div class="flex justify-center items-center space-x-1.5 mt-1.5">
                        <span id="counter-note" class="text-[9px] text-gray-500 uppercase tracking-wider font-bold text-cyan-400">Tông Môn Chân Truyền</span>
                        <div class="h-3 w-[1px] bg-slate-800"></div>
                        <label class="flex items-center space-x-1 cursor-pointer">
                            <input type="checkbox" id="auto-breakthrough-toggle" onchange="toggleAutoBreakthrough()" class="rounded bg-slate-950 border-slate-800 text-cyan-500 focus:ring-0 w-3 h-3">
                            <span class="text-[9px] font-bold text-cyan-400 uppercase">Tự động Đột Phá</span>
                        </label>
                    </div>

                    <!-- Qi Progress -->
                    <div class="relative w-full h-4 bg-slate-950 rounded-full p-[2px] border border-gray-800/80 shadow-inner overflow-hidden mt-3">
                        <div id="qi-progress-bar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-indigo-500 transition-all duration-300" style="width: 0%"></div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span class="text-[9px] font-mono font-bold text-white drop-shadow-[0_1px_1.5px_rgba(0,0,0,0.8)]">
                                <span id="qi-current">0</span> / <span id="qi-required">10,000</span>
                            </span>
                        </div>
                    </div>

                    <!-- Giao diện Gia Trì Linh Thạch khi sắp Đột Phá -->
                    <div id="breakthrough-options-panel" class="hidden bg-slate-950/80 border border-yellow-500/30 p-2 rounded-xl mt-3 flex justify-between items-center text-left">
                        <div>
                            <span class="text-[9px] text-yellow-400 font-bold block uppercase">Cơ duyên Đột Phá:</span>
                            <span class="text-[8.5px] text-gray-400">Tỉ lệ thành công cơ bản: <span id="base-success-rate-text" class="text-green-400 font-bold">85%</span></span>
                        </div>
                        <label class="flex items-center space-x-1 bg-amber-950/40 px-2 py-1 rounded border border-amber-900/40 cursor-pointer">
                            <input type="checkbox" id="bless-breakthrough-toggle" onchange="toggleBlessBreakthrough()" class="rounded bg-slate-950 border-slate-800 text-yellow-500 focus:ring-0 w-3 h-3">
                            <span class="text-[8.5px] font-bold text-yellow-300 uppercase">Gia trì (+20% tỉ lệ / 200💎)</span>
                        </label>
                    </div>

                    <div class="bg-slate-950/60 p-2.5 rounded-xl border border-slate-900 mt-3 text-[10px] flex justify-between items-center text-left">
                        <div>
                            <span class="text-gray-500 block text-[8.5px] uppercase font-bold">Hấp thu Tiên Khí:</span>
                            <span id="rate-auto" class="text-cyan-400 font-mono font-bold">0 /s</span>
                        </div>
                        <div class="text-right">
                            <span class="text-gray-500 block text-[8.5px] uppercase font-bold">Nô bộc khai khoáng: <span id="slave-count" class="text-yellow-500 font-bold">0</span> người</span>
                            <span id="slave-mining-rate" class="text-amber-400 font-mono font-bold">+0 Đá/s</span>
                        </div>
                    </div>
                </div>

                <!-- Meditation Button -->
                <button id="btn-action-master" onclick="triggerCentralLogic()" class="w-full py-3 bg-gradient-to-r from-cyan-600 to-indigo-700 hover:from-cyan-500 hover:to-indigo-600 font-bold rounded-xl border border-cyan-500/20 active:scale-98 transition transform">
                    <span id="btn-action-text" class="font-immortal tracking-wider text-xs">TOẠ THIỀN NGƯNG KHÍ</span>
                </button>
            </div>

            <!-- TAB 2: TÚI ĐỒ, CHẾ TẠO & LINH THÚ -->
            <div id="view-inventory" class="hidden flex-1 flex flex-col py-4 overflow-hidden">
                <div class="flex space-x-1.5 mb-3 bg-slate-950 p-1 rounded-lg border border-slate-900">
                    <button id="sub-inv-items" onclick="switchSubInventory('items')" class="flex-1 py-1 text-[10px] font-bold rounded text-cyan-400 bg-cyan-500/10 border border-cyan-500/20">KHO ĐỒ</button>
                    <button id="sub-inv-craft" onclick="switchSubInventory('craft')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">LUYỆN KHÍ</button>
                    <button id="sub-inv-alchemy" onclick="switchSubInventory('alchemy')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">LUYỆN ĐAN</button>
                    <button id="sub-inv-pets" onclick="switchSubInventory('pets')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">LINH THÚ</button>
                </div>
                <div class="flex-1 overflow-y-auto space-y-2 pr-1" id="inv-dynamic-container"></div>
            </div>

            <!-- TAB 3: GIA TỘC TRUYỀN THỪA -->
            <div id="view-skills" class="hidden flex-1 flex flex-col py-4 overflow-hidden">
                <div class="flex space-x-1.5 mb-3 bg-slate-950 p-1 rounded-lg border border-slate-900">
                    <button id="sub-skills-vohoc" onclick="switchSubSkills('vohoc')" class="flex-1 py-1 text-[10px] font-bold rounded text-cyan-400 bg-cyan-500/10 border border-cyan-500/20">CÔNG PHÁP</button>
                    <button id="sub-skills-daolu" onclick="switchSubSkills('daolu')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">ĐẠO LỮ</button>
                    <button id="sub-skills-family" onclick="switchSubSkills('family')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">GIA PHẢ VẠN THẾ</button>
                </div>
                <div class="flex-1 overflow-y-auto space-y-2 pr-1" id="skills-dynamic-container"></div>
            </div>

            <!-- TAB 4: TRANH ĐOẠT -->
            <div id="view-battles" class="hidden flex-1 flex flex-col py-4 overflow-hidden">
                <div class="flex space-x-1.5 mb-3 bg-slate-950 p-1 rounded-lg border border-slate-900">
                    <button id="sub-battles-tower" onclick="switchSubBattles('tower')" class="flex-1 py-1 text-[10px] font-bold rounded text-cyan-400 bg-cyan-500/10 border border-cyan-500/20">VÔ HẠN THÁP</button>
                    <button id="sub-battles-pvp" onclick="switchSubBattles('pvp')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">ĐẠO ĐÀI PVP</button>
                    <button id="sub-battles-clan" onclick="switchSubBattles('clan')" class="flex-1 py-1 text-[10px] font-bold rounded text-gray-400">LOẠN CHIẾN</button>
                </div>
                <div class="flex-1 overflow-y-auto space-y-3 pr-1" id="battles-dynamic-container"></div>
            </div>

            <!-- TAB 5: KHAI THÁC -->
            <div id="view-gathering" class="hidden flex-1 flex flex-col py-4 overflow-hidden">
                <div class="grid grid-cols-2 gap-2 mb-3" id="gather-zones-list"></div>
                <div class="flex-1 bg-black/80 rounded-xl border border-slate-900 p-2.5 flex flex-col overflow-hidden">
                    <div class="flex justify-between items-center text-[9px] text-gray-500 border-b border-slate-900 pb-1.5 mb-2 font-mono">
                        <span>NHẬT KÝ KHAI THÁC</span>
                        <span id="gather-status" class="text-cyan-400">TĨNH LẶNG</span>
                    </div>
                    <div id="gather-console" class="flex-1 overflow-y-auto font-mono text-[9px] space-y-1 text-slate-300 pr-1">
                        <span class="text-gray-600 italic">Hồn thần hòa mình vào hư không vô hạn...</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- BOTTOM NAV PANEL -->
        <div class="w-full glass-tab py-2.5 px-1 flex justify-around items-center z-20">
            <button id="nav-cultivate" onclick="navigateMainTab('cultivate')" class="flex flex-col items-center p-1 rounded text-cyan-400">
                <span class="text-base">🧘‍♂️</span>
                <span class="text-[9px] font-bold mt-0.5">Tu Luyện</span>
            </button>
            <button id="nav-inventory" onclick="navigateMainTab('inventory')" class="flex flex-col items-center p-1 rounded text-gray-400">
                <span class="text-base">🏺</span>
                <span class="text-[9px] font-bold mt-0.5">Túi & Thú</span>
            </button>
            <button id="nav-skills" onclick="navigateMainTab('skills')" class="flex flex-col items-center p-1 rounded text-gray-400">
                <span class="text-base">📖</span>
                <span class="text-[9px] font-bold mt-0.5">Gia Tộc</span>
            </button>
            <button id="nav-battles" onclick="navigateMainTab('battles')" class="flex flex-col items-center p-1 rounded text-gray-400">
                <span class="text-base">⚔️</span>
                <span class="text-[9px] font-bold mt-0.5">Tranh Đoạt</span>
            </button>
            <button id="nav-gathering" onclick="navigateMainTab('gathering')" class="flex flex-col items-center p-1 rounded text-gray-400">
                <span class="text-base">🗺️</span>
                <span class="text-[9px] font-bold mt-0.5">Bí Cảnh</span>
            </button>
        </div>

        <!-- ================= LÔI KIẾP OVERLAY ================= -->
        <div id="overlay-tribulation" class="absolute inset-0 z-50 bg-slate-950/98 hidden flex flex-col items-center justify-between p-6">
            <canvas id="lightning-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-10"></canvas>
            
            <div class="text-center z-20 w-full pt-4">
                <h3 class="font-immortal text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-b from-cyan-300 via-indigo-400 to-purple-500 tracking-wider">CỬU TRÙNG THIÊN KIẾP</h3>
                <p id="trib-title-details" class="text-xs text-yellow-400 font-bold mt-1">Độ kiếp thăng hoa</p>
                <p class="text-[9px] text-gray-500 italic">Thiên lôi oanh kích cực mạnh! Linh thú sẽ chia sẻ 25% sát thương gánh chịu!</p>
                <div class="mt-2 flex justify-center text-[9px] text-orange-400 font-semibold" id="tribulation-element-notice">
                    Thiên lôi mang thuộc tính gánh chịu...
                </div>
            </div>

            <div class="z-20 w-full flex flex-col items-center my-auto">
                <div class="text-center mb-3">
                    <span id="trib-strike-text" class="font-immortal text-sm text-indigo-300">Nhắm mắt dồn toàn ý chí nghênh phạt...</span>
                </div>
                <div class="relative w-24 h-24 flex items-center justify-center border border-indigo-500/20 bg-slate-950/80 rounded-full mb-4">
                    <span class="text-5xl animate-pulse">🧘‍♂️</span>
                </div>

                <!-- HP Tracker -->
                <div class="w-full max-w-xs space-y-1.5 px-4">
                    <div class="flex justify-between text-[10px]">
                        <span class="text-red-400 font-bold">SINH MỆNH (HP):</span>
                        <span id="trib-hp-display" class="text-white font-mono font-bold">100/100</span>
                    </div>
                    <div class="w-full h-2 bg-slate-900 rounded-full overflow-hidden p-[1px] border border-slate-800">
                        <div id="trib-hp-fill" class="h-full bg-gradient-to-r from-red-600 to-rose-500 rounded-full" style="width: 100%"></div>
                    </div>
                    <div class="flex justify-between text-[9px] pt-1">
                        <span class="text-cyan-400">Linh khí bão hòa:</span>
                        <span id="trib-qi-display" class="font-mono text-cyan-300">0</span>
                    </div>
                </div>
            </div>

            <div class="z-20 w-full max-w-xs pb-4 flex flex-col space-y-2">
                <div class="grid grid-cols-2 gap-2">
                    <button onclick="invocateShieldBarrier()" class="py-2.5 bg-gradient-to-r from-blue-600 to-indigo-800 text-white font-bold text-[10px] rounded-xl border border-indigo-400/30">
                        VẬN KHÍ ĐỠ ĐÒN<br><span class="text-[8px] text-indigo-200">(-500 Linh Khí)</span>
                    </button>
                    <button onclick="consumePillDuringTribulation()" class="py-2.5 bg-gradient-to-r from-teal-600 to-emerald-700 text-white font-bold text-[10px] rounded-xl border border-emerald-400/30">
                        NUỐT HỒI XUÂN ĐAN<br><span class="text-[8px] text-emerald-200" id="trib-potion-count">0 Đan</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- ================= FACTION SELECTION ================= -->
        <div id="overlay-faction-selection" class="absolute inset-0 z-50 bg-black/95 hidden flex flex-col items-center justify-center p-6">
            <h3 class="font-immortal text-2xl text-amber-400 font-extrabold tracking-widest text-center mb-2">ĐẠI ĐẠO CHI LỘ</h3>
            <p class="text-[10px] text-gray-400 text-center mb-6">Đã vượt qua lôi kiếp tiên môn, đạo hữu quyết định quy y đạo cốt hay ma căn?</p>
            <div class="grid grid-cols-2 gap-4 w-full">
                <div onclick="selectPathChoice('Tiên')" class="bg-teal-950/20 border border-teal-500/40 p-4 rounded-xl flex flex-col items-center cursor-pointer hover:bg-teal-950/40 transition">
