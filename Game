                try {
                    const parsed = JSON.parse(saved);
                    state = { ...state, ...parsed };
                    
                    if (!state.materials) state.materials = {};
                    if (!state.children) state.children = [];
                    if (!state.slaves) state.slaves = 0;
                    if (!state.pets) state.pets = []; // Tránh lỗi bản cũ thiếu trường pets
                    if (state.clanFame === undefined) state.clanFame = 10;
                    if (state.isAuto === undefined) state.isAuto = true;
                    if (state.autoBreakthrough === undefined) state.autoBreakthrough = true;
                    if (state.gameYear === undefined) state.gameYear = 1;
                    if (state.gameMonth === undefined) state.gameMonth = 1;
                    if (state.towerStage === undefined) state.towerStage = 1;
                    if (state.pvpPoints === undefined) state.pvpPoints = 0;

                    if (state.spiritRoot === undefined) state.spiritRoot = "Thường Căn";
                    if (state.spiritRootBuff === undefined) state.spiritRootBuff = 0.00;
                    if (state.element === undefined) state.element = "Kim";
                    if (state.blessBreakthrough === undefined) state.blessBreakthrough = false;

                    const now = Date.now();
                    const secondsPassed = Math.floor((now - state.lastSave) / 1000);
                    if (secondsPassed > 30) {
                        const allowedTime = Math.min(secondsPassed, 172800); 
                        
                        const gameMonthsPassed = Math.floor(allowedTime / 5);
                        const gameYearsPassed = Math.floor(gameMonthsPassed / 12);
                        const residualMonths = gameMonthsPassed % 12;

                        state.gameYear += gameYearsPassed;
                        state.gameMonth += residualMonths;
                        if (state.gameMonth > 12) {
                            state.gameMonth -= 12;
                            state.gameYear++;
                        }

                        if (gameYearsPassed > 0) {
                            ageAllFamilyMembers(gameYearsPassed);
                        }

                        const qiGained = allowedTime * state.autoPower;
                        const slaveStones = allowedTime * state.slaves * 0.5;

                        state.qi = Math.min(state.qi + qiGained, state.maxQi);
                        state.gems += Math.floor(slaveStones);

                        document.getElementById('off-time').innerText = `${gameYearsPassed} Năm ${residualMonths} Tháng`;
                        document.getElementById('off-qi').innerText = "+" + formatNumber(qiGained);
                        document.getElementById('off-gems').innerText = "+" + formatNumber(Math.floor(slaveStones)) + " Linh Thạch";
                        document.getElementById('modal-offline-report').classList.remove('hidden');
                    }
                } catch (e) {
                    console.error("Thiên cơ trục trặc:", e);
                }
            }
        }

        /* --- STATS CALCULATION CORE --- */
        function recalculateStats() {
            let baseAutoVal = 0.5; // Điều chỉnh giảm tốc độ ngưng khí cơ bản (Cực kỳ lâu)
            let maxHpVal = 100;

            const totalTierLvl = state.worldIndex * 30 + state.realmIndex * 10 + state.level;
            maxHpVal += totalTierLvl * 65;

            // Đắp chỉ số từ 9 Công Pháp
            state.skills.forEach(sk => {
                if (sk.level > 0) {
                    if (sk.type === 'auto') {
                        baseAutoVal += sk.level * sk.bonus;
                    } else if (sk.type === 'hp_boost') {
                        maxHpVal += sk.level * sk.bonus;
                    }
                }
            });

            // Đắp từ Đạo lữ hảo cảm
            state.companions.forEach(comp => {
                if (comp.active) {
                    baseAutoVal += comp.intimacy * comp.bonus + 5; // Giảm bớt lượng buff
                }
            });

            // Đắp từ Vạn thế gia tộc
            state.children.forEach(child => {
                const lvl = child.level || 1;
                let mul = 1;
                if (child.partner) mul = 1.3; 

                let boost = 0.5; // Giảm 4 lần buff từ con cái tránh mất cân bằng
                if (child.talent === 'Tiên Thể') boost = 25;
                else if (child.talent === 'Thánh Thể') boost = 10;
                else if (child.talent === 'Linh Thể') boost = 4;
                else if (child.talent === 'Ma Huyết (Dị Biến)') boost = -3; 
                
                baseAutoVal += Math.floor(lvl * boost * mul);
                maxHpVal += Math.floor(lvl * boost * 4 * mul);
            });

            // Trang bị
            const slots = ['weapon', 'armor', 'accessory', 'artifact'];
            slots.forEach(slot => {
                const item = state.equipment[slot];
                if (item && (item.durability || 0) > 0) {
                    if (slot === 'armor' || slot === 'artifact') {
                        baseAutoVal += item.bonus;
                    } else {
                        baseAutoVal += Math.floor(item.bonus * 0.4); // Giảm mạnh buff từ trang bị
                    }
                }
            });

            // CHỈ SỐ BUFF TỪ LINH THÚ (PET)
            let petPowerBonus = 0;
            state.pets.forEach(pet => {
                petPowerBonus += pet.level * pet.basePower * 0.15;
            });

            if (state.faction === 'Tiên') {
                baseAutoVal = Math.floor(baseAutoVal * 1.3);
                maxHpVal = Math.floor(maxHpVal * 1.5);
            } else if (state.faction === 'Ma') {
                baseAutoVal = Math.floor(baseAutoVal * 1.5);
            }

            // BUFF LINH CĂN RNG TRỰC TIẾP LÊN TỐC ĐỘ HẤP THU LINH KHÍ
            let spiritRootMultiplier = 1.0 + (state.spiritRootBuff || 0.0);
            baseAutoVal = Math.floor(baseAutoVal * spiritRootMultiplier);

            state.autoPower = Math.max(0.5, baseAutoVal);
            state.maxHp = Math.max(100, maxHpVal);

            if (state.hp > state.maxHp) state.hp = state.maxHp;

            // Yêu cầu Linh Khí (Tăng cực kỳ khó lên thêm một số 0)
            const realms = getCurrentRealmsDatabase();
            const currRealm = realms[state.realmIndex];
            state.maxQi = Math.floor(currRealm.baseQi * Math.pow(currRealm.mult, state.level - 1));

            // Combat power (Cộng thêm sức mạnh của Linh Thú)
            const combatPower = (totalTierLvl * 1500) + (state.autoPower * 30) + (state.maxHp * 10) + petPowerBonus;
            document.getElementById('power-display').innerText = formatNumber(combatPower);
        }

        function getCurrentRealmsDatabase() {
            if (state.worldIndex === 1) return REALMS_LINH;
            if (state.worldIndex === 2) return REALMS_TIEN;
            return REALMS_PHAN;
        }

        function formatNumber(num) {
            if (num >= 1000000000000) return (num / 1000000000000).toFixed(2) + 'T';
            if (num >= 1000000000) return (num / 1000000000).toFixed(2) + 'B';
            if (num >= 1000000) return (num / 1000000).toFixed(2) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'k';
            return Math.floor(num).toLocaleString('vi-VN');
        }

