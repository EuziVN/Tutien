                                    `<span class="text-[8px] text-amber-500 font-bold block mt-1 font-mono">Độ bền: ${dur}/100</span>` : ''}
                            </div>
                            <div class="flex flex-col gap-1.5 items-end">
                                <div class="flex space-x-1.5">
                                    ${item.type === 'hp_pill' || item.type === 'qi_pill' ? 
                                        `<button onclick="usePillItem(${index})" class="px-2 py-1 bg-teal-950 text-teal-300 border border-teal-800 rounded text-[9px] font-bold">Dùng</button>` :
                                        `<button onclick="equipGearItem(${index})" class="px-2 py-1 bg-indigo-950 text-indigo-300 border border-indigo-800 rounded text-[9px] font-bold">Mặc</button>`
                                    }
                                    <button onclick="discardInventoryItem(${index})" class="px-2 py-1 bg-rose-950/40 text-rose-300 rounded text-[9px]">&times;</button>
                                </div>
                                ${canRepair ? 
                                    `<button onclick="repairInventoryItem(${index}, ${repairCost})" class="px-2 py-0.5 bg-yellow-950/50 text-yellow-300 border border-yellow-800/40 rounded text-[8px] font-bold">Sửa (${repairCost} LT)</button>` : ''}
                            </div>
                        </div>
                    `;
                });
            } else if (subInv === 'craft') {
                CRAFT_RECIPES.forEach(recipe => {
                    const haveMat = state.materials[recipe.costMat] || 0;
                    const scaleFactor = state.worldIndex * 3 + state.realmIndex * 1.5 + 1; // Tăng nhẹ giá đúc
                    const finalCost = recipe.costGems * scaleFactor;
                    const canCraft = haveMat >= recipe.costQty && state.gems >= finalCost;

                    container.innerHTML += `
                        <div class="bg-slate-950/70 p-3 rounded-xl border border-slate-900 flex justify-between items-center">
                            <div>
                                <span class="text-xs font-bold rarity-${recipe.rarity}">${recipe.name}</span>
                                <span class="text-[9px] text-gray-400 block mt-0.5">Sát lực cơ sở: +${recipe.baseBonus}</span>
                                <span class="text-[9px] text-gray-500 block mt-0.5">Nguyên liệu: ${recipe.costQty}x ${recipe.costMat} (${haveMat} sở hữu)</span>
                            </div>
                            <button onclick="craftGearItem('${recipe.id}', ${finalCost})" class="px-3 py-1.5 ${canCraft ? 'bg-amber-600 text-white font-bold' : 'bg-slate-800 text-gray-500 cursor-not-allowed'} text-[9px] rounded transition">
                                Đúc (${formatNumber(finalCost)} LT)
                            </button>
                        </div>
                    `;
                });
            } else if (subInv === 'alchemy') {
                ALCHEMY_RECIPES.forEach(recipe => {
                    const haveMat = state.materials[recipe.costMat] || 0;
                    const scaleFactor = state.worldIndex * 3 + state.realmIndex * 1.5 + 1;
                    const finalCost = recipe.costGems * scaleFactor;
                    const canBrew = haveMat >= recipe.costQty && state.gems >= finalCost;

                    container.innerHTML += `
                        <div class="bg-slate-950/70 p-3 rounded-xl border border-slate-900 flex justify-between items-center">
                            <div>
                                <span class="text-xs font-bold rarity-${recipe.rarity}">${recipe.name}</span>
                                <span class="text-[9px] text-gray-400 block mt-0.5">${recipe.desc}</span>
                                <span class="text-[9px] text-gray-500 block mt-0.5">Tiêu hao: ${recipe.costQty}x ${recipe.costMat}</span>
                            </div>
                            <button onclick="brewAlchemyPill('${recipe.id}', ${finalCost})" class="px-3 py-1.5 ${canBrew ? 'bg-emerald-600 text-white font-bold' : 'bg-slate-800 text-gray-500 cursor-not-allowed'} text-[9px] rounded transition">
                                Luyện (${formatNumber(finalCost)} LT)
                            </button>
                        </div>
                    `;
                });
            } else if (subInv === 'pets') {
                // GIAO DIỆN LINH THÚ MỚI
                let petShopHeader = `
                    <div class="bg-indigo-950/20 p-3 rounded-xl border border-indigo-900/30 flex flex-col space-y-1.5 mb-3">
                        <h4 class="text-xs font-bold text-indigo-300">🐾 BỒI DƯỠNG LINH THÚ THƯỢNG CỔ</h4>
                        <p class="text-[8.5px] text-gray-400">Mua trứng ấp Linh Thú hộ mệnh. Linh Thú sẽ trực tiếp gia tăng Lực Chiến và san sẻ sát thương khi đạo hữu Độ Kiếp Thiên Lôi!</p>
                    </div>
                `;
                container.innerHTML += petShopHeader;

                // Hiển thị Linh thú đã sở hữu
                if (state.pets.length > 0) {
                    container.innerHTML += `<h5 class="text-[9px] font-bold text-cyan-400 uppercase tracking-wider mb-2">Linh Thú Đang Đồng Hành:</h5>`;
                    state.pets.forEach((pet, index) => {
                        const levelCost = Math.floor(pet.cost * 0.4 * Math.pow(1.5, pet.level));
                        const canLevelUp = state.gems >= levelCost;

                        container.innerHTML += `
                            <div class="bg-slate-950/80 p-3 rounded-xl border border-cyan-500/20 flex justify-between items-center mb-3">
                                <div class="flex items-center space-x-2">
                                    <span class="text-3xl">${pet.emoji}</span>
                                    <div>
                                        <span class="text-xs font-bold text-white">${pet.name} <span class="text-[8px] bg-cyan-950 text-cyan-300 px-1 py-0.2 rounded font-mono">Lvl ${pet.level}</span></span>
                                        <span class="text-[8.5px] text-gray-400 block">Công kích: +${formatNumber(pet.level * pet.basePower)} | Đỡ lôi kiếp: ${(pet.hpShare * 100).toFixed(0)}%</span>
                                    </div>
                                </div>
                                <button onclick="levelUpPet(${index}, ${levelCost})" class="px-2.5 py-1.5 ${canLevelUp ? 'bg-cyan-600 text-slate-950 font-bold' : 'bg-slate-800 text-gray-500'} text-[9px] rounded-lg">
                                    Nuôi Lvl<br><span class="text-[7.5px]">(${formatNumber(levelCost)} LT)</span>
                                </button>
                            </div>
                        `;
                    });
                }

                // Cửa hàng Linh thú bán bằng Linh Thạch
                container.innerHTML += `<h5 class="text-[9px] font-bold text-yellow-400 uppercase tracking-wider mt-3 mb-2">Triệu Hồi Thần Thú Cổ Đại:</h5>`;
                PETS_DATABASE.forEach(petData => {
                    const alreadyOwned = state.pets.some(p => p.id === petData.id);
                    const canBuy = state.gems >= petData.cost && !alreadyOwned;

                    container.innerHTML += `
                        <div class="bg-slate-950/70 p-3 rounded-xl border border-slate-900 flex justify-between items-center mb-2">
                            <div class="flex items-center space-x-2.5">
                                <span class="text-3xl">${petData.emoji}</span>
                                <div class="max-w-[190px]">
                                    <span class="text-xs font-bold text-yellow-300">${petData.name}</span>
                                    <span class="text-[8px] text-gray-400 block leading-tight mt-0.5">${petData.desc}</span>
                                </div>
                            </div>
                            ${alreadyOwned ? 
                                `<span class="text-[9px] text-gray-500 font-bold uppercase mr-1">Đã Hữu</span>` :
                                `<button onclick="buyPet('${petData.id}', ${petData.cost})" class="px-3 py-1.5 ${canBuy ? 'bg-amber-600 text-white font-bold' : 'bg-slate-800 text-gray-500 cursor-not-allowed'} text-[9px] rounded-lg">
                                    Ấp Trứng<br><span class="text-[8px]">${formatNumber(petData.cost)} LT</span>
                                </button>`
                            }
                        </div>
                    `;
                });
            }
        }

        function buyPet(petId, cost) {
            if (state.gems >= cost) {
                const petData = PETS_DATABASE.find(p => p.id === petId);
                if (!petData) return;

                state.gems -= cost;
                // Thêm bản sao linh thú vào trạng thái của đạo hữu
                state.pets.push({
                    id: petData.id,
                    name: petData.name,
                    emoji: petData.emoji,
                    level: 1,
                    cost: petData.cost,
                    basePower: petData.basePower,
                    hpShare: petData.hpShare
                });

                recalculateStats();
                renderInventorySubViews();
                updateAllUI();
                playSoundAscend();
                sendSystemNotification(`Triệu hồi thành công Linh Thú Thượng Cổ [${petData.name}]! Thần thú ngự lâm!`, "success");
            } else {
                sendSystemNotification("Cơ duyên thiếu hụt Linh Thạch để triệu hồi Thần thú!", "error");
            }
        }

        function levelUpPet(index, cost) {
            const pet = state.pets[index];
            if (!pet) return;

            if (state.gems >= cost) {
                state.gems -= cost;
                pet.level++;
                recalculateStats();
                renderInventorySubViews();
                updateAllUI();
                playSoundMeditation();
                sendSystemNotification(`Đút ăn tiên thạch bồi dưỡng [${pet.name}] thăng lên cấp ${pet.level}!`, "success");
            } else {
                sendSystemNotification("Thiếu Linh Thạch bồi bổ thần thú!", "error");
            }
        }

        function craftGearItem(id, finalCost) {
            const recipe = CRAFT_RECIPES.find(r => r.id === id);
            if (!recipe) return;

            const haveMat = state.materials[recipe.costMat] || 0;
            if (haveMat >= recipe.costQty && state.gems >= finalCost) {
                state.materials[recipe.costMat] -= recipe.costQty;
                state.gems -= finalCost;

                const rngRatio = 0.8 + Math.random() * 0.7;
                const finalBonus = Math.floor(recipe.baseBonus * rngRatio);
                const qualityPct = Math.floor(rngRatio * 100);

                const newItem = {
                    id: 'gear_' + Date.now(),
                    name: `${recipe.name} (Chất lượng: ${qualityPct}%)`,
                    type: recipe.type,
                    rarity: recipe.rarity,
                    bonus: finalBonus,
                    durability: 100,
                    desc: recipe.type === 'weapon' || recipe.type === 'accessory' ? 
                          `Tấn công lực chiến bạo pháp +${finalBonus}` : 
                          `Hấp thu đan hải tăng mạnh +${finalBonus} /s`
                };
                state.inventory.push(newItem);

                recalculateStats();
                renderInventorySubViews();
                updateAllUI();
                sendSystemNotification(`Đúc thành thần khí hiệu năng ${qualityPct}%!`, "success");
            } else {
                sendSystemNotification("Thiếu nguyên thạch hoặc tiên thạch rèn khí!", "error");
            }
        }

        function brewAlchemyPill(id, finalCost) {
            const recipe = ALCHEMY_RECIPES.find(r => r.id === id);
            if (!recipe) return;

            const haveMat = state.materials[recipe.costMat] || 0;
            if (haveMat >= recipe.costQty && state.gems >= finalCost) {
                state.materials[recipe.costMat] -= recipe.costQty;
                state.gems -= finalCost;

                let newItem = {
                    id: 'pill_' + Date.now(),
                    name: recipe.name,
                    type: recipe.type,
                    rarity: recipe.rarity,
                    desc: recipe.desc
                };

                if (recipe.type === 'hp_pill') {
                    newItem.healHp = recipe.healHp;
                } else {
                    newItem.bonus = recipe.qiBonus;
                }

                state.inventory.push(newItem);
                renderInventorySubViews();
                updateAllUI();
                sendSystemNotification(`Luyện đan chế đắc phẩm [${recipe.name}] thành công!`, "success");
            } else {
                sendSystemNotification("Thiếu linh thảo hoặc thạch năng luyện đan!", "error");
            }
        }

        function usePillItem(idx) {
            const item = state.inventory[idx];
            if (!item) return;

            if (item.type === 'hp_pill') {
                state.hp = Math.min(state.maxHp, state.hp + item.healHp);
                sendSystemNotification(`Uống đan dược, khôi phục +${item.healHp} HP!`, "success");
            } else if (item.type === 'qi_pill') {
                absorbQi(item.bonus);
                sendSystemNotification(`Đan khí nhập thế bổ sung +${formatNumber(item.bonus)} Linh Khí!`, "success");
            }

            state.inventory.splice(idx, 1);
            renderInventorySubViews();
            updateAllUI();
        }

        function equipGearItem(idx) {
            const item = state.inventory[idx];
            if (!item) return;

            const slot = item.type;
            const currentlyEquipped = state.equipment[slot];

            if (currentlyEquipped) state.inventory.push(currentlyEquipped);

            state.equipment[slot] = item;
            state.inventory.splice(idx, 1);

            recalculateStats();
            renderInventorySubViews();
            updateAllUI();
            sendSystemNotification(`Đã mang trang bị [${item.name}]!`, "success");
        }

        function repairInventoryItem(idx, cost) {
            const item = state.inventory[idx];
            if (!item) return;

            if (state.gems >= cost) {
                state.gems -= cost;
                item.durability = 100;
                recalculateStats();
                renderInventorySubViews();
                updateAllUI();
                sendSystemNotification(`Hồi phục độ bền thành công!`, "success");
            } else {
                sendSystemNotification("Thiếu Linh Thạch sửa đồ!", "error");
            }
        }

        function unequipItem(slot) {
            const item = state.equipment[slot];
            if (!item) return;

            state.equipment[slot] = null;
            state.inventory.push(item);

            recalculateStats();
            updateAllUI();
            if (currentTab === 'inventory') renderInventorySubViews();
            sendSystemNotification(`Tháo bỏ trang bị.`, "info");
        }

        function discardInventoryItem(idx) {
            state.inventory.splice(idx, 1);
            renderInventorySubViews();
        }

        /* --- TRANH ĐOẠT & LOẠN CHIẾN THỰC THẾ --- */
        function renderBattlesSubViews() {
            const container = document.getElementById('battles-dynamic-container');
            container.innerHTML = '';

            if (subBattles === 'tower') {
                container.innerHTML = `
                    <div class="bg-slate-950/50 p-4 rounded-xl border border-cyan-950/40 text-center space-y-3">
                        <span class="text-4xl block animate-bounce">🛕</span>
                        <h4 class="font-bold text-sm text-cyan-300 font-immortal">VÔ HẠN THIÊN THÁP</h4>
                        <p class="text-[10px] text-gray-400">Chinh phạt quái vật giữ tháp. Đoạt tiên châu thăng tiên hải bồi bổ tu vi.</p>
                        <div class="bg-black/50 p-2.5 rounded border border-slate-900 font-mono text-xs">
                            Tầng tháp đạt tới: <span class="text-yellow-400 font-bold">Tầng ${state.towerStage}</span>
                        </div>
                        <button onclick="challengeTowerStage()" class="w-full py-2 bg-gradient-to-r from-cyan-600 to-purple-700 text-white font-bold text-xs rounded-xl transition active:scale-95">
                            KHIÊU CHIẾN ẢI TẦNG THÁP
                        </button>
                    </div>
                `;
            } else if (subBattles === 'pvp') {
                container.innerHTML = `
                    <div class="bg-slate-950/50 p-4 rounded-xl border border-rose-950/40 text-center space-y-3">
                        <span class="text-4xl block animate-pulse">⚔️</span>
                        <h4 class="font-bold text-sm text-rose-300 font-immortal">LUÂN HỒI ĐẠO ĐÀI PVP</h4>
                        <p class="text-[10px] text-gray-400">Tranh phong bài vị tối cao khẳng định uy thế dòng tộc.</p>
                        <div class="bg-black/50 p-2.5 rounded border border-slate-900 font-mono text-xs">
                            Hạng tích lũy: <span class="text-emerald-400 font-bold">${state.pvpPoints} Điểm</span>
                        </div>
                        <button onclick="simulatePVPArenaMatch()" class="w-full py-2 bg-gradient-to-r from-rose-600 to-orange-700 text-white font-bold text-xs rounded-xl transition active:scale-95">
                            QUYẾT ĐẤU TRANH ĐOẠT
                        </button>
                    </div>
                `;
            } else if (subBattles === 'clan') {
                container.innerHTML = `
                    <div class="bg-slate-950/50 p-4 rounded-xl border border-indigo-900/40 text-center space-y-3">
                        <span class="text-4xl block animate-pulse">🚩</span>
                        <h4 class="font-bold text-sm text-indigo-300 font-immortal">GIA TỘC LOẠN CHIẾN</h4>
                        <p class="text-[10px] text-gray-400">Đại chiến phe phái cướp linh quặng, thu giữ tà tu đem về làm nô bộc tự đào thạch năng!</p>
                        <div class="grid grid-cols-2 gap-2 max-w-xs mx-auto">
                            <button onclick="initiateClanWar(3)" class="py-1.5 bg-slate-900 text-[9px] font-bold border border-slate-800 rounded-lg hover:border-cyan-500 text-white">Loạn Chiến 3vs3</button>
                            <button onclick="initiateClanWar(5)" class="py-1.5 bg-slate-900 text-[9px] font-bold border border-slate-800 rounded-lg hover:border-cyan-500 text-white">Loạn Chiến 5vs5</button>
                            <button onclick="initiateClanWar(10)" class="py-1.5 bg-slate-900 text-[9px] font-bold border border-slate-800 rounded-lg hover:border-cyan-500 text-white">Loạn Chiến 10vs10</button>
                            <button onclick="initiateClanWar(20)" class="py-1.5 bg-slate-900 text-[9px] font-bold border border-slate-800 rounded-lg hover:border-cyan-500 text-white">Đại Loạn Chiến 20vs20</button>
                        </div>
                    </div>
                `;
            }
        }

        function challengeTowerStage() {
            const reqPower = 200 + state.towerStage * 180;
            const totalPower = (state.worldIndex * 30000) + (state.realmIndex * 10000) + (state.autoPower * 25) + (state.maxHp * 8);

            if (totalPower >= reqPower) {
                const prize = 200 + state.towerStage * 100;
                state.gems += prize;
                state.towerStage++;
                updateAllUI();
                renderBattlesSubViews();
                sendSystemNotification(`Đăng tháp tầng ${state.towerStage - 1} đoạt được +${prize} Linh Thạch!`, "success");
            } else {
                sendSystemNotification("Không đủ chiến lực chống chịu yêu thuật ma pháp!", "error");
            }
        }

        function simulatePVPArenaMatch() {
            const roll = Math.random();
            if (roll < 0.65) {
                state.pvpPoints += 30;
                state.gems += 500;
                sendSystemNotification("Độc chiếm thắng lợi trên đài vị đạo đài! Nhận +30 tích lũy.", "success");
            } else {
                state.pvpPoints = Math.max(0, state.pvpPoints - 15);
                sendSystemNotification("Bại chiêu trước đạo hữu cường giả, trừ 15 tích lũy.", "error");
            }
            updateAllUI();
            renderBattlesSubViews();
        }

        /* --- LOẠN CHIẾN CHI TIẾT --- */
        function initiateClanWar(size) {
            const allies = [];
            allies.push({
                name: "Đạo Hữu (Ta)",
                hp: state.maxHp,
                maxHp: state.maxHp,
                atk: Math.floor(state.autoPower * 0.45) + 20,
                turnsLeft: 2,
                element: state.element, 
                id: 'ally_p'
            });

            state.companions.forEach((c, idx) => {
                if (c.active && allies.length < size) {
                    allies.push({
                        name: `Vợ: ${c.name}`,
                        hp: Math.floor(state.maxHp * 0.8),
                        maxHp: Math.floor(state.maxHp * 0.8),
                        atk: Math.floor(c.intimacy * c.bonus * 1.5) + 30,
                        turnsLeft: 2,
                        element: ELEMENTS[idx % ELEMENTS.length],
                        id: `ally_sp_${idx}`
                    });
                }
            });

            state.children.forEach((c, idx) => {
                if (allies.length < size) {
                    let childAtk = (c.level || 1) * 12 + 15;
                    if (c.talent === 'Tiên Thể') childAtk *= 4.5;
                    allies.push({
                        name: `Đời ${c.generation || 1}: ${c.name}`,
                        hp: Math.floor(state.maxHp * 0.7),
                        maxHp: Math.floor(state.maxHp * 0.7),
                        atk: childAtk,
                        turnsLeft: 2,
                        element: ELEMENTS[idx % ELEMENTS.length],
                        id: `ally_ch_${idx}`
                    });
                }
            });

            while (allies.length < size) {
                allies.push({
                    name: `Gia tộc môn sinh #${allies.length}`,
                    hp: Math.floor(state.maxHp * 0.5),
                    maxHp: Math.floor(state.maxHp * 0.5),
                    atk: Math.floor(state.autoPower * 0.15) + 10,
                    turnsLeft: 2,
                    element: ELEMENTS[allies.length % ELEMENTS.length],
                    id: `ally_npc_${allies.length}`
                });
            }

            const enemies = [];
            const chosenSurname = "Hắc Sát Tộc";

            for (let i = 0; i < size; i++) {
                const enemyHp = Math.floor(state.maxHp * (0.5 + Math.random() * 0.6));
                const enemyAtk = Math.floor(state.autoPower * (0.15 + Math.random() * 0.2)) + 12;
                enemies.push({
                    name: `${chosenSurname} Tà Tu #${i + 1}`,
                    hp: enemyHp,
                    maxHp: enemyHp,
                    atk: enemyAtk,
                    turnsLeft: 2,
                    element: ELEMENTS[Math.floor(Math.random() * ELEMENTS.length)], 
                    id: `enemy_${i}`
                });
            }

            activeWar = {
                size: size,
                allies: allies,
                enemies: enemies,
                selectedAllyId: null,
                selectedEnemyId: null,
                round: 1
            };

            document.getElementById('war-title').innerText = `GIA TỘC LOẠN CHIẾN ĐỘT KÍCH ${size}VS${size}`;
            document.getElementById('clan-war-logs').innerHTML = `<p class="text-gray-500 italic">Trận loạn thế khốc liệt khai cuộc! Lượt của bạn!</p>`;
            document.getElementById('overlay-clan-war').classList.remove('hidden');

            renderWarSquads();
            updateWarUIState();
        }

        function renderWarSquads() {
            if (!activeWar) return;

            const allyBox = document.getElementById('ally-squad-container');
            allyBox.innerHTML = '';
            activeWar.allies.forEach(a => {
                const isDead = a.hp <= 0;
                const isSelected = activeWar.selectedAllyId === a.id;
                const cardClass = isDead ? 'bg-slate-900 border-gray-800 opacity-40' : 
                                  (isSelected ? 'bg-emerald-950 border-cyan-400 ring-2 ring-cyan-400' : 'bg-slate-900 border-slate-700 hover:border-cyan-500');

                const relation = ELEMENT_RELATIONS[a.element];
                const elementColorClass = relation ? relation.color : 'text-gray-400';

                allyBox.innerHTML += `
                    <div onclick="selectAllyInWar('${a.id}')" class="p-1.5 w-16 text-center border rounded-lg cursor-pointer transition ${cardClass}">
                        <span class="text-xl block">${isDead ? '💀' : '🧘‍♂️'}</span>
                        <span class="text-[6px] text-gray-300 block truncate font-bold">${a.name}</span>
                        <span class="text-[5px] font-bold ${elementColorClass} block">[Hệ ${a.element}]</span>
                        <span class="text-[6px] text-red-400 font-mono font-bold block">${Math.floor(a.hp)}/${a.maxHp}</span>
                        <span class="text-[5px] text-yellow-500 block">Atk: ${a.turnsLeft}</span>
                    </div>
                `;
            });

            const enemyBox = document.getElementById('enemy-squad-container');
            enemyBox.innerHTML = '';
            activeWar.enemies.forEach(e => {
                const isDead = e.hp <= 0;
                const isSelected = activeWar.selectedEnemyId === e.id;
                const cardClass = isDead ? 'bg-slate-900 border-gray-800 opacity-40' : 
                                  (isSelected ? 'bg-rose-950 border-rose-400 ring-2 ring-rose-400' : 'bg-slate-900 border-slate-700 hover:border-rose-500');

                const relation = ELEMENT_RELATIONS[e.element];
                const elementColorClass = relation ? relation.color : 'text-gray-400';

                enemyBox.innerHTML += `
                    <div onclick="selectEnemyInWar('${e.id}')" class="p-1.5 w-16 text-center border rounded-lg cursor-pointer transition ${cardClass}">
                        <span class="text-xl block">${isDead ? '💀' : '👹'}</span>
                        <span class="text-[6px] text-gray-300 block truncate font-bold">${e.name}</span>
                        <span class="text-[5px] font-bold ${elementColorClass} block">[Hệ ${e.element}]</span>
                        <span class="text-[6px] text-red-400 font-mono font-bold block">${Math.floor(e.hp)}/${e.maxHp}</span>
                        <span class="text-[5px] text-amber-500 block">Dính Atk: ${e.turnsLeft}</span>
                    </div>
                `;
            });
        }

        function updateWarUIState() {
            if (!activeWar) return;
            const aliveAllies = activeWar.allies.filter(a => a.hp > 0).length;
            const aliveEnemies = activeWar.enemies.filter(e => e.hp > 0).length;

            document.getElementById('ally-alive-count').innerText = aliveAllies;
            document.getElementById('enemy-alive-count').innerText = aliveEnemies;
        }

        function selectAllyInWar(id) {
            if (!activeWar) return;
            const ally = activeWar.allies.find(a => a.id === id);
            if (ally && ally.hp > 0) {
                activeWar.selectedAllyId = id;
                renderWarSquads();
            }
        }

        function selectEnemyInWar(id) {
            if (!activeWar) return;
            const enemy = activeWar.enemies.find(e => e.id === id);
            if (enemy && enemy.hp > 0) {
                activeWar.selectedEnemyId = id;
                renderWarSquads();
            }
        }

        function executeManualWarAttack() {
            if (!activeWar) return;
            if (!activeWar.selectedAllyId || !activeWar.selectedEnemyId) {
                sendSystemNotification("Vui lòng chọn 1 đồng minh và 1 địch thủ!", "error");
                return;
            }

            const ally = activeWar.allies.find(a => a.id === activeWar.selectedAllyId);
            const enemy = activeWar.enemies.find(e => e.id === activeWar.selectedEnemyId);

            if (ally.turnsLeft <= 0) {
                sendSystemNotification("Tu sĩ đã cạn lượt công!", "error");
                return;
            }

            playSoundAttack();
            ally.turnsLeft--;
            
            let dmg = Math.floor(ally.atk * (0.85 + Math.random() * 0.3));

            const relation = ELEMENT_RELATIONS[ally.element];
            let elementNotice = "";
            if (relation && relation.beats === enemy.element) {
                dmg = Math.floor(dmg * 1.5); 
                elementNotice = `<span class="text-yellow-400 font-bold">[KHẮC CHẾ]</span> `;
            } else if (relation && relation.beatenBy === enemy.element) {
                dmg = Math.floor(dmg * 0.7); 
                elementNotice = `<span class="text-slate-500">[BỊ KHẮC]</span> `;
            }

            enemy.hp = Math.max(0, enemy.hp - dmg);

            const logs = document.getElementById('clan-war-logs');
            logs.innerHTML += `<p class="text-emerald-400">⚔️ ${elementNotice}[${ally.name} - Hệ ${ally.element}] công kích [${enemy.name} - Hệ ${enemy.element}] gây -${dmg} HP!</p>`;
            logs.scrollTop = logs.scrollHeight;

            activeWar.selectedAllyId = null;
            activeWar.selectedEnemyId = null;

            renderWarSquads();
            updateWarUIState();

            const aliveEnemies = activeWar.enemies.filter(e => e.hp > 0);
            if (aliveEnemies.length === 0) {
                setTimeout(concludeClanWarSuccess, 800);
                return;
            }

            const totalTurnsLeft = activeWar.allies.reduce((sum, a) => sum + (a.hp > 0 ? a.turnsLeft : 0), 0);
            if (totalTurnsLeft <= 0) {
                document.getElementById('btn-war-attack').disabled = true;
                setTimeout(executeEnemyTurns, 1200);
            }
        }

        function executeEnemyTurns() {
            if (!activeWar) return;
            const logs = document.getElementById('clan-war-logs');
            logs.innerHTML += `<p class="text-yellow-500 italic font-bold">⚠️ Đến lượt Hắc Thế Lực phản công cực mạnh!</p>`;
            
            const aliveAllies = activeWar.allies.filter(a => a.hp > 0);
            const aliveEnemies = activeWar.enemies.filter(e => e.hp > 0);

            aliveEnemies.forEach(e => {
                if (aliveAllies.length > 0) {
                    const target = aliveAllies[Math.floor(Math.random() * aliveAllies.length)];
                    let enemyDmg = Math.floor(e.atk * (0.8 + Math.random() * 0.4));

                    const relation = ELEMENT_RELATIONS[e.element];
                    let elementNotice = "";
                    if (relation && relation.beats === target.element) {
                        enemyDmg = Math.floor(enemyDmg * 1.5);
                        elementNotice = `<span class="text-red-500 font-bold">[ĐỊCH KHẮC]</span> `;
                    } else if (relation && relation.beatenBy === target.element) {
                        enemyDmg = Math.floor(enemyDmg * 0.7);
                        elementNotice = `<span class="text-emerald-500">[ĐỊCH BỊ KHẮC]</span> `;
                    }

                    target.hp = Math.max(0, target.hp - enemyDmg);
                    logs.innerHTML += `<p class="text-red-400">👹 ${elementNotice}[${e.name} - Hệ ${e.element}] oanh kích [${target.name} - Hệ ${target.element}] -${enemyDmg} HP!</p>`;
                }
            });

            logs.scrollTop = logs.scrollHeight;

            activeWar.allies.forEach(a => { if (a.hp > 0) a.turnsLeft = 2; });
            activeWar.round++;

            logs.innerHTML += `<p class="text-cyan-300 font-bold">--- Bắt Đầu Vòng Đấu Thứ ${activeWar.round} ---</p>`;
            document.getElementById('btn-war-attack').disabled = false;

            renderWarSquads();
            updateWarUIState();

            const currentAliveAllies = activeWar.allies.filter(a => a.hp > 0);
            if (currentAliveAllies.length === 0) {
                setTimeout(concludeClanWarFailure, 800);
            }
        }

        function concludeClanWarSuccess() {
            if (!activeWar) return;

            const prizeStones = activeWar.size * 600 + Math.floor(Math.random() * 800);
            const prizeFame = activeWar.size * 15;
            
            let captiveGained = 0;
            if (Math.random() < 0.6) {
                captiveGained = Math.max(1, Math.floor(activeWar.size * 0.45));
            }

            state.gems += prizeStones;
            state.clanFame += prizeFame;
            state.slaves += captiveGained;

            document.getElementById('overlay-clan-war').classList.add('hidden');
            sendSystemNotification(`ĐẠI THẮNG LOẠN CHIẾN! Nhận +${formatNumber(prizeStones)} Linh Thạch, +${prizeFame} Uy Danh và bắt giữ ${captiveGained} Tà Tu làm Nô Bộc đào mỏ quặng!`, "success");
            
            activeWar = null;
            updateAllUI();
        }

        function concludeClanWarFailure() {
            document.getElementById('overlay-clan-war').classList.add('hidden');
            activeWar = null;
            sendSystemNotification("Thất bại nhục nhã! Gia tộc hao hụt uy danh thê thảm!", "error");
            state.clanFame = Math.max(0, state.clanFame - 12);
            updateAllUI();
        }

        function surrenderWar() {
            document.getElementById('overlay-clan-war').classList.add('hidden');
            activeWar = null;
            sendSystemNotification("Chủ động thu quân rút lui an toàn.", "info");
        }

        /* --- KHAI THÁC BÍ CẢNH --- */
        function renderGatheringModule() {
            const container = document.getElementById('gather-zones-list');
            container.innerHTML = '';

            GATHER_ZONES.forEach(gz => {
                const isLocked = state.worldIndex < (gz.minWorld || 0);
                if (isLocked) {
                    container.innerHTML += `
                        <div class="bg-slate-950/20 p-2 rounded-xl border border-slate-900 opacity-40 flex flex-col justify-between h-20 relative">
                            <span class="absolute inset-0 flex items-center justify-center bg-black/60 rounded-xl text-[8px] text-red-500 font-bold tracking-widest">LINH GIỚI MỞ KHÓA</span>
                            <span class="text-[10px] font-bold text-gray-500">${gz.name}</span>
                        </div>
                    `;
                } else {
                    container.innerHTML += `
                        <div class="bg-slate-950/60 p-2.5 rounded-xl border border-cyan-950 flex flex-col justify-between h-20">
                            <div>
                                <h4 class="font-bold text-[10px] text-gray-200">${gz.name}</h4>
                                <span class="text-[8px] text-gray-500 block">Sản phẩm: ${gz.mat} (${gz.duration}s)</span>
                            </div>
                            <button onclick="startGatheringProcess('${gz.id}')" class="w-full py-1 bg-cyan-950 hover:bg-cyan-900 border border-cyan-800 text-cyan-300 rounded text-[9px] font-bold">
                                KHAI THÁC
                            </button>
                        </div>
                    `;
                }
            });
        }

        function appendGatherConsole(text) {
            const consoleEl = document.getElementById('gather-console');
            if (state.activeGather && consoleEl.innerHTML.includes('hòa mình vào hư không')) {
                consoleEl.innerHTML = '';
            }

            const timestamp = new Date().toLocaleTimeString('vi-VN', { hour12: false });
            const p = document.createElement('p');
            p.innerHTML = `<span class="text-gray-500 font-mono">[${timestamp}]</span> ${text}`;
            consoleEl.appendChild(p);
            consoleEl.scrollTop = consoleEl.scrollHeight;
        }

        function startGatheringProcess(zoneId) {
            if (state.activeGather) {
                sendSystemNotification("Nguyên thần đang tuần hành khai thác ở một bí cảnh khác!", "error");
                return;
            }

            const zone = GATHER_ZONES.find(z => z.id === zoneId);
            if (!zone) return;

            state.activeGather = {
                zoneId: zone.id,
                start: Date.now(),
                duration: zone.duration,
                ticksLeft: zone.duration
            };

            document.getElementById('gather-status').innerText = "ĐANG KHAI THÁC";
            document.getElementById('gather-status').className = "text-yellow-400 font-bold animate-pulse";
            appendGatherConsole(`<span class="text-cyan-300">Xuất khiếu nguyên thần tiến nhập vào [${zone.name}] thu hoạch linh thạch tinh tú...</span>`);
        }

        function runGatheringTick() {
            if (!state.activeGather) return;

            const adv = state.activeGather;
            const zone = GATHER_ZONES.find(z => z.id === adv.zoneId);

            adv.ticksLeft--;

            if (adv.ticksLeft > 0 && adv.ticksLeft % 3 === 0) {
                appendGatherConsole('<span class="text-gray-500 font-mono">Đang thanh tủy cát bụi, thu thập chân khí tinh thạch...</span>');
            }

            if (adv.ticksLeft <= 0) {
                state.materials[zone.mat] = (state.materials[zone.mat] || 0) + zone.qty;
                state.activeGather = null;

                document.getElementById('gather-status').innerText = "TĨNH LẶNG";
                document.getElementById('gather-status').className = "text-cyan-400";

                appendGatherConsole(`<span class="text-green-400 font-bold">Thành công mang về kho: +${zone.qty}x ${zone.mat}!</span>`);
                updateAllUI();
                sendSystemNotification(`Nhận thành công ${zone.qty}x ${zone.mat}!`, "success");
            }
        }

        /* --- CƠ DUYÊN THIÊN KỲ --- */
        function triggerCoDuyenChance() {
            if (activeCoDuyen || activeTribulation || activeWar) return;

            const events = [
                {
                    title: "THƯỢNG CỔ DI TÍCH",
                    icon: "🏛️",
                    desc: "Tọa thiền vô thức rơi vào mật cảnh linh hồn, trước mắt đạo hữu xuất hiện một tòa điện thờ vỡ nát mang hơi thở cổ đại.",
                    choice: "Hiến tế 100 Linh Thạch mở hạp",
                    bonusText: "Mở ra 3x Huyền Linh Kim cực hiếm!",
                    action: () => {
                        state.gems = Math.max(0, state.gems - 100);
                        state.materials['Huyền linh kim'] = (state.materials['Huyền linh kim'] || 0) + 3;
                    }
                },
                {
                    title: "TIÊN NHÂN CHỈ LỘ",
                    icon: "🧙‍♂️",
                    desc: "Một vị lão nhân râu tóc bạc phơ bước ra từ sương mù, gõ nhẹ vào trán đạo hữu truyền thụ tâm pháp ngưng khí.",
                    choice: "Lĩnh ngộ",
                    bonusText: "Nhận ngay +15,000 Linh Khí bồi bổ tu vi!",
                    action: () => {
                        absorbQi(15000);
                    }
                },
                {
                    title: "MA THÚ QUY PHỤC",
                    icon: "🐉",
                    desc: "Đạo hữu dạo bước trong thung lũng, bắt gặp một con ấu long linh khí đầy mình bị thương nặng. Sau khi trị thương, nó quyết định dâng hiến vạn bảo quy phụng.",
                    choice: "Thu nhận",
                    bonusText: "Tăng +1,500 Uy Danh gia tộc và nhận 800 Linh Thạch!",
                    action: () => {
                        state.gems += 800;
                        state.clanFame += 1500;
                    }
                }
            ];

            const selected = events[Math.floor(Math.random() * events.length)];
            activeCoDuyen = selected;

            document.getElementById('co-duyen-icon').innerText = selected.icon;
            document.getElementById('co-duyen-title').innerText = selected.title;
            document.getElementById('co-duyen-desc').innerText = selected.desc;
            document.getElementById('co-duyen-bonus-box').innerHTML = `
                <div class="font-bold text-yellow-400">🎁 Phần Thưởng Cơ Duyên:</div>
                <div class="mt-1">${selected.bonusText}</div>
            `;
            document.getElementById('co-duyen-btn').innerText = selected.choice;

            document.getElementById('modal-co-duyen').classList.remove('hidden');
            playSound(440, 'sine', 0.5, 0.2);
        }

        function acceptCoDuyen() {
            if (!activeCoDuyen) return;
            activeCoDuyen.action();
            document.getElementById('modal-co-duyen').classList.add('hidden');
            activeCoDuyen = null;
            updateAllUI();
            sendSystemNotification("Nhận cơ duyên thành công, đại lộ thăng hoa!", "success");
        }

        /* --- HEARTBEAT ENGINE --- */
        let lastTickStamp = Date.now();
        function coreEngineHeartbeat() {
            const now = Date.now();
            const dt = (now - lastTickStamp) / 1000;
            lastTickStamp = now;

            // Hồi HP tự nhiên
            if (state.hp < state.maxHp && !activeTribulation && !activeWar) {
                state.hp = Math.min(state.maxHp, state.hp + 1.2 * dt);
                document.getElementById('char-hp-text').innerText = `${Math.floor(state.hp)}/${state.maxHp}`;
                const hpPct = Math.max(0, (state.hp / state.maxHp) * 100);
                document.getElementById('char-hp-fill').style.width = `${hpPct}%`;
            }

            // Tự động tọa thiền tụ khí tu vi (Cực kỳ trường kỳ)
            if (state.isAuto && state.autoPower > 0 && !state.readyToBreakthrough) {
                absorbQi(state.autoPower * dt);

                if (Math.random() < 0.003) {
                    triggerCoDuyenChance();
                }
            }

            // Nô bộc tự động đào quặng thạch 
            if (state.slaves > 0 && !activeTribulation) {
                state.gems += state.slaves * 0.5 * dt;
                document.getElementById('currency-gems').innerText = formatNumber(state.gems);
            }

            // Bí cảnh tick
            if (state.activeGather) {
                const passed = Math.floor((now - state.activeGather.start) / 1000);
                const remain = state.activeGather.duration - passed;
                if (remain !== state.activeGather.ticksLeft) {
                    state.activeGather.ticksLeft = remain;
                    runGatheringTick();
                }
            }

            // Lôi kiếp tick
            if (activeTribulation) {
                runTribulationTick();
                drawLightningFrames();
            }
        }

        function spawnVisualParticle() {
            const container = document.getElementById('ambient-layer');
            const p = document.createElement('div');
            p.className = 'absolute w-[1.5px] h-[1.5px] bg-cyan-400/20 rounded-full pointer-events-none';
            p.style.left = Math.random() * 100 + '%';
            p.style.top = '100%';
            p.style.transition = 'transform 6s cubic-bezier(0.1, 0.8, 0.3, 1), opacity 6s';
            container.appendChild(p);
            
            setTimeout(() => {
                p.style.transform = `translateY(-${window.innerHeight + 50}px) scale(2.5)`;
                p.style.opacity = '0';
            }, 50);

            setTimeout(() => p.remove(), 6000);
        }

        function sendSystemNotification(msg, type = 'success') {
            const container = document.getElementById('toast-layer');
            const toast = document.createElement('div');

            let border = 'border-l-4 border-cyan-500 bg-slate-950/90 text-white';
            if (type === 'error') border = 'border-l-4 border-rose-500 bg-slate-950/90 text-white';
            if (type === 'warning') border = 'border-l-4 border-amber-500 bg-slate-950/90 text-white';
            if (type === 'info') border = 'border-l-4 border-indigo-500 bg-slate-950/90 text-white';

            toast.className = `${border} p-2.5 rounded-lg shadow-2xl text-[10px] font-semibold flex items-center justify-between transition-all duration-300 opacity-0 -translate-y-2 pointer-events-auto`;
            toast.innerHTML = `
                <span>${msg}</span>
                <button onclick="this.parentElement.remove()" class="text-gray-400 hover:text-white ml-2 text-sm leading-none">&times;</button>
            `;

            container.appendChild(toast);
            setTimeout(() => { toast.classList.remove('opacity-0', '-translate-y-2'); }, 10);

            setTimeout(() => {
                toast.classList.add('opacity-0', '-translate-y-2');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

    </script>
