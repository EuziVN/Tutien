        /* --- XỬ LÝ GIA TRÌ LINH THẠCH --- */
        function toggleBlessBreakthrough() {
            state.blessBreakthrough = document.getElementById('bless-breakthrough-toggle').checked;
            if (state.blessBreakthrough) {
                if (state.gems < 200) {
                    sendSystemNotification("Thiếu Linh Thạch để mua bảo châu gia trì đột phá!", "error");
                    document.getElementById('bless-breakthrough-toggle').checked = false;
                    state.blessBreakthrough = false;
                } else {
                    sendSystemNotification("Đã chuẩn bị 200 Linh Thạch gia trì đại trận! Tăng +20% tỉ lệ thành công.", "warning");
                }
            } else {
                sendSystemNotification("Hủy bỏ gia trì Linh Thạch.", "info");
            }
            setCentralActionUI(true);
        }

        /* --- XỬ LÝ ĐỘT PHÁ CẢNH GIỚI (CÓ RNG THẤT BẠI CỰC KHÓ) --- */
        function handleBreakthroughAction() {
            if (state.level < TIER_STAGE_MAX) {
                // ĐỘT PHÁ TIỂU CẢNH GIỚI
                let baseRate = Math.max(20, 85 - state.level * 6.5); // Tỉ lệ thành công giảm sâu hơn bản cũ
                let finalRate = baseRate;

                let usedBless = false;
                if (state.blessBreakthrough) {
                    if (state.gems >= 200) {
                        state.gems -= 200;
                        finalRate += 20; 
                        usedBless = true;
                    } else {
                        sendSystemNotification("Thiếu Linh Thạch gia trì đột phá trực tiếp!", "error");
                        document.getElementById('bless-breakthrough-toggle').checked = false;
                        state.blessBreakthrough = false;
                        return;
                    }
                }

                finalRate = Math.min(99, finalRate); // Đột phá luôn có tỉ lệ thất bại tối thiểu 1% nghịch thiên
                const roll = Math.random() * 100;

                if (roll <= finalRate) {
                    state.qi = 0;
                    state.level++;
                    playSoundAscend();
                    sendSystemNotification(`Đột phá thành công tiểu cảnh giới lên tầng ${state.level}!`, "success");
                    
                    state.readyToBreakthrough = false;
                    state.blessBreakthrough = false;
                    document.getElementById('bless-breakthrough-toggle').checked = false;
                    document.getElementById('breakthrough-options-panel').classList.add('hidden');
                    
                    recalculateStats();
                    setCentralActionUI(false);
                    updateAllUI();
                } else {
                    // THẤT BẠI ĐỘT PHÁ (Mất tới 50% linh khí bão hòa và gây trọng thương)
                    const qiLoss = Math.floor(state.maxQi * 0.50); 
                    state.qi = Math.max(0, state.qi - qiLoss);
                    state.hp = Math.max(10, state.hp - 45); // Trọng thương sâu hơn (-45 HP)

                    const app = document.getElementById('game-app');
                    app.classList.add('shake');
                    setTimeout(() => { app.classList.remove('shake'); }, 400);

                    playSoundLôiKiếp();
                    sendSystemNotification(`ĐỘT PHÁ THẤT BẠI! Nguyên thần bị phản phệ nứt vỡ: -${formatNumber(qiLoss)} Linh Khí và -45 HP!`, "error");

                    state.readyToBreakthrough = false;
                    state.blessBreakthrough = false;
                    document.getElementById('bless-breakthrough-toggle').checked = false;
                    document.getElementById('breakthrough-options-panel').classList.add('hidden');

                    setCentralActionUI(false);
                    updateAllUI();
                }
            } else {
                initiateTribulationFlow();
            }
        }

        function absorbQi(val) {
            if (state.readyToBreakthrough) return;
            state.qi += val;
            if (state.qi >= state.maxQi) {
                state.qi = state.maxQi;
                state.readyToBreakthrough = true;
                setCentralActionUI(true);

                if (state.autoBreakthrough) {
                    if (state.level < TIER_STAGE_MAX) {
                        setTimeout(handleBreakthroughAction, 500);
                    }
                }
            }
            updateAllUI();
        }

